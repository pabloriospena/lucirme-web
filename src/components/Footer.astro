---
// Footer reutilizable
---

<footer class="bg-slate-950 border-t border-slate-800 py-12">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-4 gap-8">
      
      <!-- Marca -->
      <div>
        <h3 class="text-lg font-bold text-white mb-4">
          LuciRMe <span class="text-cyan-400">Ai</span>
        </h3>
        <p class="text-slate-400 text-sm">
          Product Management + IA sin complicaciones.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white font-semibold mb-3">Navegación</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#servicios" class="text-slate-400 hover:text-cyan-400">Servicios</a></li>
          <li><a href="#metodo" class="text-slate-400 hover:text-cyan-400">Metodología</a></li>
          <li><a href="/bitacora" class="text-slate-400 hover:text-cyan-400">Bitácora</a></li>
          <li><a href="#contacto" class="text-slate-400 hover:text-cyan-400">Contacto</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-white font-semibold mb-3">Legal</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="text-slate-400 hover:text-cyan-400">Privacidad</a></li>
          <li><a href="#" class="text-slate-400 hover:text-cyan-400">Términos</a></li>
        </ul>
      </div>

      <!-- Redes -->
      <div>
        <h4 class="text-white font-semibold mb-3">Conecta</h4>
        <div class="flex space-x-4">
          <a href="#" class="text-slate-400 hover:text-cyan-400">LinkedIn</a>
          <a href="#" class="text-slate-400 hover:text-cyan-400">X</a>
          <a href="#" class="text-slate-400 hover:text-cyan-400">GitHub</a>
        </div>
      </div>

    </div>

    <div class="border-t border-slate-800 mt-8 pt-8 text-center text-slate-500 text-sm">
      © 2026 LuciRMe Ai. Construido con Astro + Tailwind + IA local.
    </div>
  </div>
</footer>