---
// Tarjeta para entradas de la bitácora
export interface Props {
  date: string;
  tags: string[];
  title: string;
  excerpt: string;
  url: string;
}
const { date, tags, title, excerpt, url } = Astro.props;
---

<article class="border border-slate-700 p-5 rounded-lg hover:border-cyan-500 transition">
  <!-- Meta -->
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <span class="text-xs bg-slate-800 text-amber-400 px-2 py-1 rounded">#{tag}</span>
    ))}
    <time class="text-slate-500 text-xs ml-auto">{date}</time>
  </div>
  
  <!-- Título + Extracto -->
  <h3 class="text-lg font-semibold text-white mb-2">
    <a href={url} class="hover:text-cyan-400 transition">{title}</a>
  </h3>
  <p class="text-slate-300 text-sm leading-relaxed">{excerpt}</p>
  
  <!-- Leer más -->
  <a href={url} class="inline-block mt-3 text-cyan-400 text-sm hover:underline">
    Leer entrada →
  </a>
</article>