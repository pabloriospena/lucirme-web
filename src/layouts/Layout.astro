---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}
const { title = "LuciRMe Ai", description = "Conectar tecnología y personas para desbloquear el potencial y ganar velocidad." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Enlace al Favicon para que se vea en la pestaña del navegador -->
    <link rel="icon" type="image/png" href="/favicon.svg" />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <slot />
  </body>
</html>