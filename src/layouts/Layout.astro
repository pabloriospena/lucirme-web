---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title?: string;
}
const { title = "LuciRMe Ai" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Product Management + IA sin complicaciones. Equipos no técnicos, estudiantes y startups." />
  </head>
  <body class="bg-slate-900 text-slate-200 font-sans">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>