---
import Layout from '../layouts/Layout.astro'
---

<Layout title="CheckTomate · Valida transferencias en segundos | AiTomate">

  <!-- ============================================ -->
  <!-- AI TOMATE BRAND BOOK v1.0 (SCOPED & ISOLATED)-->
  <!-- ============================================ -->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Serif+Display&display=swap');

    #ct-page {
      /* Reset base para vencer cualquier herencia */
      all: initial;
      font-family: 'DM Sans', system-ui, sans-serif;
      color: #1A1F2C;
      background: #F1F4F9;
      line-height: 1.6;
      box-sizing: border-box;
      width: 100%;
      overflow-x: hidden;
    }
    #ct-page *, #ct-page *::before, #ct-page *::after {
      box-sizing: border-box;
    }

    /* === BRAND TOKENS === */
    #ct-page {
      --ct-tomato: #E23D28;
      --ct-green: #2ECC71;
      --ct-green-hover: #27AE60;
      --ct-blue: #3498DB;
      --ct-midnight: #1A1F2C;
      --ct-silver: #F1F4F9;
      --ct-sand: #FDF8F2;
      
      --ct-text-primary: #1A1F2C;
      --ct-text-secondary: #4A5568;
      --ct-text-muted: #718096;
      --ct-text-inverse: #FFFFFF;
      
      --ct-border: #E2E8F0;
      --ct-border-dark: #334155;
      
      --ct-shadow-sm: 0 2px 4px rgba(26,31,44,0.04);
      --ct-shadow-md: 0 4px 12px rgba(26,31,44,0.06);
      --ct-shadow-lg: 0 8px 24px rgba(26,31,44,0.08);
      --ct-shadow-glass: 0 8px 32px rgba(26,31,44,0.05);
      
      --ct-r-8: 8px;   /* Chips */
      --ct-r-12: 12px; /* Botones */
      --ct-r-16: 16px; /* Cards */
      --ct-r-24: 24px; /* Modales */
      
      --ct-space-xs: 4px;
      --ct-space-sm: 8px;
      --ct-space-md: 12px;
      --ct-space-lg: 16px;
      --ct-space-xl: 24px;
      --ct-space-2xl: 32px;
      --ct-space-3xl: 40px;
      --ct-space-4xl: 48px;
      --ct-space-5xl: 64px;
    }

    /* === DARK MODE === */
    #ct-page[data-theme="dark"] {
      --ct-bg-page: var(--ct-midnight);
      --ct-bg-surface: #252B3B;
      --ct-bg-sand: #2A3142;
      --ct-text-primary: #F1F4F9;
      --ct-text-secondary: #94A3B8;
      --ct-text-muted: #64748B;
      --ct-border: #334155;
      --ct-shadow-md: 0 4px 12px rgba(0,0,0,0.25);
      --ct-shadow-glass: 0 8px 32px rgba(0,0,0,0.2);
    }

    /* === TYPOGRAPHY (Brand Book Exacto) === */
    #ct-page h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 48px;
      font-weight: 400;
      line-height: 1.1;
      color: var(--ct-text-primary);
      margin: 0 0 var(--ct-space-lg) 0;
      letter-spacing: -0.02em;
    }
    #ct-page h2 {
      font-family: 'DM Sans', sans-serif;
      font-size: 32px;
      font-weight: 800;
      line-height: 1.2;
      color: var(--ct-text-primary);
      margin: 0 0 var(--ct-space-xl) 0;
      letter-spacing: -0.01em;
    }
    #ct-page h3 {
      font-family: 'DM Sans', sans-serif;
      font-size: 24px;
      font-weight: 500;
      line-height: 1.3;
      color: var(--ct-text-primary);
      margin: 0 0 var(--ct-space-md) 0;
    }
    #ct-page p {
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.6;
      color: var(--ct-text-secondary);
      margin: 0;
    }
    #ct-page .text-sm { font-size: 14px; color: var(--ct-text-muted); }
    #ct-page .text-green { color: var(--ct-green); }
    #ct-page .text-tomato { color: var(--ct-tomato); }
    #ct-page .text-inverse { color: var(--ct-text-inverse); }
    #ct-page .text-center { text-align: center; }
    #ct-page .font-medium { font-weight: 500; }
    #ct-page .font-semibold { font-weight: 600; }
    #ct-page strong { font-weight: 700; color: var(--ct-text-primary); }

    /* === LAYOUT & UTILS === */
    #ct-page .container {
      width: 100%;
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 var(--ct-space-lg);
    }
    @media(min-width:768px) { #ct-page .container { padding: 0 var(--ct-space-xl); } }
    
    #ct-page .flex { display: flex; }
    #ct-page .flex-col { flex-direction: column; }
    #ct-page .items-center { align-items: center; }
    #ct-page .justify-between { justify-content: space-between; }
    #ct-page .justify-center { justify-content: center; }
    #ct-page .gap-sm { gap: var(--ct-space-sm); }
    #ct-page .gap-md { gap: var(--ct-space-md); }
    #ct-page .gap-lg { gap: var(--ct-space-lg); }
    #ct-page .gap-xl { gap: var(--ct-space-xl); }
    #ct-page .grid { display: grid; }
    #ct-page .grid-3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--ct-space-xl); }
    #ct-page .grid-2 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--ct-space-xl); }
    #ct-page .hidden { display: none; }
    #ct-page .mt-lg { margin-top: var(--ct-space-lg); }
    #ct-page .mt-xl { margin-top: var(--ct-space-xl); }
    #ct-page .mt-2xl { margin-top: var(--ct-space-2xl); }
    #ct-page .mb-lg { margin-bottom: var(--ct-space-lg); }
    #ct-page .mb-xl { margin-bottom: var(--ct-space-xl); }
    #ct-page .mb-2xl { margin-bottom: var(--ct-space-2xl); }
    #ct-page .p-xl { padding: var(--ct-space-xl); }
    #ct-page .p-2xl { padding: var(--ct-space-2xl); }
    #ct-page .py-2xl { padding-top: var(--ct-space-2xl); padding-bottom: var(--ct-space-2xl); }
    #ct-page .py-3xl { padding-top: var(--ct-space-3xl); padding-bottom: var(--ct-space-3xl); }
    #ct-page .py-4xl { padding-top: var(--ct-space-4xl); padding-bottom: var(--ct-space-4xl); }
    #ct-page .py-5xl { padding-top: var(--ct-space-5xl); padding-bottom: var(--ct-space-5xl); }
    #ct-page .space-y-md > * + * { margin-top: var(--ct-space-md); }
    #ct-page .space-y-lg > * + * { margin-top: var(--ct-space-lg); }
    #ct-page .space-y-xl > * + * { margin-top: var(--ct-space-xl); }
    #ct-page .max-w-xl { max-width: 600px; }
    #ct-page .max-w-2xl { max-width: 800px; }
    #ct-page .max-w-3xl { max-width: 960px; }
    #ct-page .mx-auto { margin-left: auto; margin-right: auto; }
    #ct-page .rounded-8 { border-radius: var(--ct-r-8); }
    #ct-page .rounded-12 { border-radius: var(--ct-r-12); }
    #ct-page .rounded-16 { border-radius: var(--ct-r-16); }
    #ct-page .rounded-24 { border-radius: var(--ct-r-24); }
    #ct-page .shadow-md { box-shadow: var(--ct-shadow-md); }
    #ct-page .shadow-lg { box-shadow: var(--ct-shadow-lg); }
    #ct-page .glass { background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid var(--ct-border); }
    #ct-page [data-theme="dark"] .glass { background: rgba(26,31,44,0.85); border-bottom: 1px solid var(--ct-border-dark); }
    #ct-page .w-full { width: 100%; }
    #ct-page .h-full { height: 100%; }
    #ct-page .overflow-x-auto { overflow-x: auto; }
    #ct-page table { width: 100%; border-collapse: collapse; }
    #ct-page th, #ct-page td { padding: var(--ct-space-md) var(--ct-space-lg); text-align: left; }
    #ct-page th { font-weight: 600; color: var(--ct-text-primary); border-bottom: 1px solid var(--ct-border); }
    #ct-page td { border-bottom: 1px solid var(--ct-border); color: var(--ct-text-secondary); }
    #ct-page [data-theme="dark"] th, #ct-page [data-theme="dark"] td { border-color: var(--ct-border-dark); }
    #ct-page code { background: rgba(0,0,0,0.05); padding: 2px 6px; border-radius: 4px; font-size: 13px; }
    #ct-page [data-theme="dark"] code { background: rgba(255,255,255,0.1); color: var(--ct-text-inverse); }

    /* === COMPONENTS === */
    #ct-page .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: var(--ct-space-sm);
      background: var(--ct-green); color: var(--ct-text-inverse);
      font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 600;
      padding: 14px 28px; border-radius: var(--ct-r-12); border: none;
      cursor: pointer; transition: all 0.2s ease; box-shadow: var(--ct-shadow-md);
    }
    #ct-page .btn-primary:hover { background: var(--ct-green-hover); transform: translateY(-1px); box-shadow: var(--ct-shadow-lg); }
    
    #ct-page .btn-secondary {
      display: inline-flex; align-items: center; justify-content: center; gap: var(--ct-space-sm);
      background: transparent; color: var(--ct-text-primary);
      font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 600;
      padding: 14px 28px; border-radius: var(--ct-r-12); border: 1.5px solid var(--ct-border);
      cursor: pointer; transition: all 0.2s ease;
    }
    #ct-page .btn-secondary:hover { border-color: var(--ct-text-primary); background: rgba(0,0,0,0.03); }
    #ct-page [data-theme="dark"] .btn-secondary:hover { background: rgba(255,255,255,0.05); }

    #ct-page .card {
      background: #FFFFFF; border: 1px solid var(--ct-border); border-radius: var(--ct-r-16);
      padding: var(--ct-space-2xl); box-shadow: var(--ct-shadow-md); transition: all 0.2s ease;
    }
    #ct-page [data-theme="dark"] .card { background: var(--ct-bg-surface); border-color: var(--ct-border-dark); }
    #ct-page .card:hover { transform: translateY(-2px); box-shadow: var(--ct-shadow-lg); }

    #ct-page .input {
      width: 100%; padding: 12px 16px; border: 1.5px solid var(--ct-border); border-radius: var(--ct-r-16);
      background: #FFFFFF; color: var(--ct-text-primary); font-family: 'DM Sans', sans-serif; font-size: 15px;
      transition: all 0.2s ease;
    }
    #ct-page [data-theme="dark"] .input { background: var(--ct-bg-surface); border-color: var(--ct-border-dark); color: var(--ct-text-inverse); }
    #ct-page .input:focus { outline: none; border-color: var(--ct-green); box-shadow: 0 0 0 3px rgba(46,204,113,0.15); }
    #ct-page .input::placeholder { color: var(--ct-text-muted); }

    #ct-page .badge {
      display: inline-flex; align-items: center; gap: var(--ct-space-xs);
      padding: 4px 12px; border-radius: var(--ct-r-8); font-size: 13px; font-weight: 500;
    }
    #ct-page .badge-green { background: rgba(46,204,113,0.1); color: var(--ct-green); }
    #ct-page .badge-tomato { background: rgba(226,61,40,0.1); color: var(--ct-tomato); }
    #ct-page .badge-blue { background: rgba(52,152,219,0.1); color: var(--ct-blue); }

    #ct-page .divider { height: 1px; background: var(--ct-border); margin: var(--ct-space-xl) 0; }
    #ct-page [data-theme="dark"] .divider { background: var(--ct-border-dark); }

    /* === SECTIONS BG === */
    #ct-page .bg-page { background: var(--ct-silver); }
    #ct-page .bg-surface { background: #FFFFFF; }
    #ct-page .bg-sand { background: var(--ct-sand); }
    #ct-page .bg-midnight { background: var(--ct-midnight); }
    #ct-page [data-theme="dark"] .bg-page { background: var(--ct-midnight); }
    #ct-page [data-theme="dark"] .bg-surface { background: var(--ct-bg-surface); }
    #ct-page [data-theme="dark"] .bg-sand { background: var(--ct-bg-sand); }

    /* === ANIMATIONS === */
    @keyframes ct-fadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
    #ct-page .fade-up { animation: ct-fadeUp 0.3s ease forwards; }

    /* === RESPONSIVE === */
    @media(max-width:767px) {
      #ct-page h1 { font-size: 36px; }
      #ct-page h2 { font-size: 26px; }
      #ct-page h3 { font-size: 20px; }
      #ct-page .grid-3, #ct-page .grid-2 { grid-template-columns: 1fr; }
      #ct-page .flex-col-sm { flex-direction: column; }
    }
  </style>

  <!-- WRAPPER ISOLADO -->
  <div id="ct-page">

    <!-- NAV -->
    <nav class="sticky top-0 z-50 glass">
      <div class="container flex items-center justify-between py-3">
        <div class="flex items-center gap-sm">
          <img src="/checktomate-logo40x40.png" alt="CheckTomate" style="height:32px;width:auto;">
          <span style="font-weight:600;font-size:17px;color:var(--ct-text-primary);">CheckTomate</span>
        </div>
        <button onclick="openCtModal()" class="btn-primary">🍅 Probar 15 días gratis</button>
      </div>
    </nav>

    <!-- HERO -->
    <header class="py-5xl bg-sand">
      <div class="container text-center max-w-3xl mx-auto">
        <div class="mb-xl flex justify-center">
          <img src="/checktomate-logo.png" alt="CheckTomate" style="height:64px;width:auto;">
        </div>
        <h1>Valida transferencias en menos de 10 segundos.<br><span class="text-green">Sin estafas. Sin hojas de cálculo manuales.</span></h1>
        <p class="max-w-xl mx-auto mb-2xl" style="font-size:18px;">CheckTomate recibe capturas por WhatsApp, verifica fecha, cuenta, duplicados y ediciones, y guarda todo automáticamente en tu Google Sheet. Configúralo en 3 minutos.</p>
        
        <div class="flex flex-col-sm justify-center gap-md mb-xl">
          <button onclick="openCtModal()" class="btn-primary">🍅 Probar 15 días gratis</button>
          <a href="#demo" class="btn-secondary">▶️ Ver demo en video</a>
        </div>

        <div class="flex justify-center gap-xl text-sm font-medium">
          <span class="flex items-center gap-sm">✓ Validación en tiempo real</span>
          <span class="flex items-center gap-sm">🔒 0 fraudes por comprobante falso</span>
          <span class="flex items-center gap-sm">📊 Reporte automático</span>
        </div>
      </div>
    </header>

    <!-- VIDEO DEMO -->
    <section id="demo" class="py-4xl bg-surface">
      <div class="container text-center max-w-3xl mx-auto">
        <h2 class="mb-md">Mira cómo funciona en 40 segundos</h2>
        <p class="mb-2xl mx-auto max-w-xl">Sin instalación. Sin configuraciones complejas. Solo WhatsApp + Google Sheet.</p>
        <video controls class="w-full rounded-16 shadow-lg" style="max-width:640px;margin:0 auto;display:block;">
          <source src="/checktomate-demo.mp4" type="video/mp4">
        </video>
      </div>
    </section>

    <!-- D.R.A.M.A. -->
    <section class="py-4xl bg-page">
      <div class="container max-w-2xl mx-auto">
        <h2 class="text-center">¿No sabes cuánto vendiste hoy por transferencias?</h2>
        <div class="space-y-xl">
          <div class="card" style="border-left:4px solid var(--ct-tomato);border-radius:0 var(--ct-r-16) var(--ct-r-16) 0;">
            <p>Pierdes horas revisando capturas una por una, mientras te arriesgas a estafas con comprobantes editados o pagos que nunca llegaron a tu cuenta.</p>
          </div>
          <div>
            <h3>La realidad de hoy</h3>
            <p>Dependes de la revisión a ojo de tu cajero, cometes errores manuales y terminas perdiendo más tiempo pasando datos a una hoja de cálculo tipo Excel que cerrando caja o atendiendo nuevos clientes.</p>
          </div>
          <div class="card" style="background:rgba(46,204,113,0.08);border-color:rgba(46,204,113,0.3);">
            <h3 class="flex items-center gap-sm">🤖 La automatización que necesitas</h3>
            <p>Con CheckTomate, tu operador solo envía la captura por WhatsApp. En menos de 10 segundos validamos fecha, cuenta destino, duplicados y posibles ediciones. Si hay alerta, el bot pregunta en el chat. Todo se guarda automáticamente en tu Google Sheet, sin copiar ni pegar.</p>
          </div>
          <div class="card bg-midnight text-inverse" style="background:var(--ct-midnight);color:var(--ct-text-inverse);border:none;">
            <h3 class="flex items-center gap-sm text-inverse">📊 La métrica que importa</h3>
            <ul class="space-y-md mt-lg" style="list-style:none;padding:0;">
              <li class="flex items-start gap-sm">✓ Ahorra <strong style="color:#fff;">+10 horas semanales</strong> en conciliación</li>
              <li class="flex items-start gap-sm">✓ <strong style="color:#fff;">0 errores</strong> de validación</li>
              <li class="flex items-start gap-sm">✓ <strong style="color:#fff;">100% de trazabilidad</strong> por pago</li>
            </ul>
            <p class="mt-lg text-sm" style="opacity:0.8;font-style:italic;">Tu caja cierra en minutos, con confianza real.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <section id="como-funciona" class="py-4xl bg-surface">
      <div class="container max-w-3xl mx-auto">
        <h2 class="text-center">De la captura al Sheet en 3 pasos simples</h2>
        <div class="grid-3 mt-xl">
          <div class="card text-center">
            <div style="height:120px;background:var(--ct-sand);border-radius:var(--ct-r-12);display:flex;align-items:center;justify-content:center;margin-bottom:var(--ct-space-lg);color:var(--ct-text-muted);font-size:13px;">Screenshot WhatsApp</div>
            <div style="width:56px;height:56px;border-radius:50%;background:rgba(46,204,113,0.12);color:var(--ct-green);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;margin:0 auto var(--ct-space-md);">1</div>
            <h3>📸 Envía la captura</h3>
            <p class="text-sm">Tu operador comparte la foto del comprobante por WhatsApp. Sin apps extra, sin logins.</p>
          </div>
          <div class="card text-center">
            <div style="height:120px;background:var(--ct-sand);border-radius:var(--ct-r-12);display:flex;align-items:center;justify-content:center;margin-bottom:var(--ct-space-lg);color:var(--ct-text-muted);font-size:13px;">Screenshot Validación</div>
            <div style="width:56px;height:56px;border-radius:50%;background:rgba(46,204,113,0.12);color:var(--ct-green);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;margin:0 auto var(--ct-space-md);">2</div>
            <h3>🤖 Validación en &lt;10s</h3>
            <p class="text-sm">CheckTomate analiza automáticamente: fecha, cuenta, código, legibilidad y ediciones.</p>
          </div>
          <div class="card text-center">
            <div style="height:120px;background:var(--ct-sand);border-radius:var(--ct-r-12);display:flex;align-items:center;justify-content:center;margin-bottom:var(--ct-space-lg);color:var(--ct-text-muted);font-size:13px;">Screenshot Google Sheet</div>
            <div style="width:56px;height:56px;border-radius:50%;background:rgba(46,204,113,0.12);color:var(--ct-green);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;margin:0 auto var(--ct-space-md);">3</div>
            <h3>📊 Decisión y registro</h3>
            <p class="text-sm">Si todo coincide → ✅ Validado. Si hay alerta → tu operador decide en el chat. Todo en tu Sheet.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- QUÉ DETECTA -->
    <section class="py-4xl bg-page">
      <div class="container max-w-3xl mx-auto">
        <h2 class="text-center">Protección inteligente contra fraudes</h2>
        <p class="text-center mb-2xl mx-auto max-w-xl">Cada transacción recibe un <strong>% de Confianza</strong>. Si el bot detecta una anomalía, te alerta al instante.</p>
        <div class="rounded-16 overflow-x-auto" style="border:1px solid var(--ct-border);background:#fff;">
          <table>
            <thead>
              <tr>
                <th>Alerta</th>
                <th>Qué significa</th>
                <th style="text-align:right;">Impacto</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="font-medium">📅 Fecha no coincide</td><td>El comprobante no es de hoy</td><td style="text-align:right;color:var(--ct-tomato);">-60%</td></tr>
              <tr><td class="font-medium">🏦 Cuenta no registrada</td><td>El pago no fue a tu cuenta oficial</td><td style="text-align:right;color:var(--ct-tomato);">-80%</td></tr>
              <tr><td class="font-medium">🔁 Código duplicado</td><td>Misma referencia usada antes</td><td style="text-align:right;color:var(--ct-tomato);">-80%</td></tr>
              <tr><td class="font-medium">🖼️ Imagen ilegible</td><td>No se pueden extraer datos clave</td><td style="text-align:right;color:#F59E0B;">-25%</td></tr>
              <tr><td class="font-medium">✏️ Posible edición</td><td>Metadatos o estructura manipulada</td><td style="text-align:right;color:var(--ct-tomato);">-90%</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-center text-sm mt-lg">💡 <strong>Validación automática</strong> = 100% confianza | <strong>Aprobación manual</strong> = confianza reducida | <strong>Rechazado</strong> = 0%</p>
      </div>
    </section>

    <!-- POR QUÉ ELEGIR -->
    <section class="py-4xl bg-surface">
      <div class="container max-w-3xl mx-auto">
        <h2 class="text-center">Diseñado para negocios que venden por WhatsApp</h2>
        <div class="grid-2 mt-xl">
          <div class="card">
            <h3 class="text-green">✓ Sin fricción para tu equipo</h3>
            <p class="text-sm">Tus operadores ya usan WhatsApp. CheckTomate se integra en su flujo natural.</p>
          </div>
          <div class="card">
            <h3 class="text-green">✓ Google Sheet siempre actualizado</h3>
            <p class="text-sm">Cada validación se registra automáticamente con fecha, operador, monto y estado.</p>
          </div>
          <div class="card">
