  <!-- SCRIPTS -->
  <script is:inline>
    // === THEME TOGGLE ===
    const ctPage = document.getElementById('ct-page');
    const ctToggle = document.getElementById('ct-theme-toggle');
    const ctIconOff = document.getElementById('ct-icon-off');
    const ctIconOn = document.getElementById('ct-icon-on');
    const ctThemeText = document.getElementById('ct-theme-text');

    // Cargar preferencia guardada o default light
    if (localStorage.getItem('ct-theme') === 'dark') { ctSetDark(); }

    function ctSetLight() {
      ctPage.removeAttribute('data-theme');
      localStorage.setItem('ct-theme', 'light');
      ctIconOff.classList.remove('hidden'); ctIconOn.classList.add('hidden');
      ctThemeText.textContent = "Modo Oscuro";
    }
    function ctSetDark() {
      ctPage.setAttribute('data-theme', 'dark');
      localStorage.setItem('ct-theme', 'dark');
      ctIconOff.classList.add('hidden'); ctIconOn.classList.remove('hidden');
      ctThemeText.textContent = "Modo Claro";
    }
    function ctToggleTheme() {
      ctPage.getAttribute('data-theme') === 'dark' ? ctSetLight() : ctSetDark();
    }

    // === MODAL & FORM ===
    function openCtModal() {
      const m = document.getElementById('ct-modal');
      m.classList.remove('hidden'); m.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      setTimeout(() => m.querySelector('.input')?.focus(), 50);
    }
    function closeCtModal() {
      const m = document.getElementById('ct-modal');
      m.classList.add('hidden'); m.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', e => { if(e.key==='Escape') closeCtModal(); });
    document.getElementById('ct-modal').addEventListener('click', e => { if(e.target.id==='ct-modal') closeCtModal(); });

    async function handleCtSubmit(e) {
      e.preventDefault();
      const form = e.target, btn = document.getElementById('ct-submit-btn'), status = document.getElementById('ct-status');
      btn.disabled = true; btn.textContent = '⏳ Enviando...'; status.classList.add('hidden');
      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('/api/checktomate-access', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
        const result = await res.json();
        if(res.ok) {
          form.reset(); status.textContent='✅ ¡Listo! Revisa tu correo.'; status.style.color='var(--ct-green)'; status.classList.remove('hidden');
          setTimeout(()=>{ closeCtModal(); status.classList.add('hidden'); btn.disabled=false; btn.textContent='🚀 Solicitar acceso'; }, 2500);
        } else { throw new Error(result.error || 'Error'); }
      } catch(err) {
        status.textContent='⚠️ '+err.message; status.style.color='var(--ct-tomato)'; status.classList.remove('hidden');
        btn.disabled=false; btn.textContent='🔄 Intentar de nuevo';
      }
    }
  </script>

