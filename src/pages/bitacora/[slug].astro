---
import Layout from '../../layouts/Layout.astro';

// 1. OBLIGATORIO: Definir las rutas estáticas
// Esto le dice a Astro qué archivos existen para generar las URLs
export const getStaticPaths = async () => {
  const allPosts = await import.meta.glob('../../../content/logs/*.md', { eager: true });
  
  return Object.entries(allPosts).map(([path, module]) => {
    // Extrae el nombre del archivo sin la extensión (ej: 2026-04-29-inicio)
    const slug = path.split('/').pop()?.replace('.md', '') || '';
    
    return {
      params: { slug },
    };
  });
};

// 2. Obtener el slug de la URL actual
const { slug } = Astro.params;

// 3. Buscar el contenido de este post específico
const allPosts = await import.meta.glob('../../../content/logs/*.md', { eager: true });

let postEntry: any = null;

for (const [filePath, module] of Object.entries(allPosts)) {
  const fileName = filePath.split('/').pop()?.replace('.md', '') || '';
  if (fileName === slug) {
    postEntry = module;
    break;
  }
}

if (!postEntry) {
  return Astro.redirect('/bitacora');
}

// 4. Extraer datos
const { frontmatter, Content } = postEntry;
const { title, date, tags } = frontmatter;
---

<Layout title={`${title} | LuciRMe Log`}>

  <article class="bg-slate-900 py-16 px-4">
    <div class="container mx-auto max-w-3xl">
      
      <!-- Botón volver -->
      <a href="/bitacora" class="text-cyan-400 hover:underline text-sm mb-6 inline-block">
        ← Volver a la bitácora
      </a>

      <!-- Cabecera del post -->
      <header class="mb-8">
        <!-- Etiquetas -->
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag: string) => (
            <span class="text-xs bg-slate-800 text-amber-400 px-2 py-1 rounded">#{tag}</span>
          ))}
        </div>

        <!-- Título -->
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{title}</h1>

        <!-- Fecha -->
        <time class="text-slate-500 text-sm">{date}</time>
      </header>

      <!-- Contenido renderizado -->
      <div class="bg-slate-800 p-6 rounded-lg prose prose-invert prose-slate max-w-none">
        <Content />
      </div>

      <!-- Firma -->
      <div class="mt-8 pt-8 border-t border-slate-700">
        <p class="text-slate-400 text-sm">— LuciRMe Log</p>
      </div>

    </div>
  </article>

</Layout>