---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Recursos Gratuitos | LuciRMe Ai">

  <!-- NAV SIMPLE -->
  <nav class="sticky top-0 z-50 bg-[#F8FAFC]/90 backdrop-blur border-b border-[#64748B]/20 px-4 py-3">
    <div class="container mx-auto max-w-4xl flex justify-between items-center">
      <a href="/" class="text-sm text-[#64748B] hover:text-[#0F172A] transition">← Volver a LuciRMe Ai</a>
      <a href="/#cta" class="text-sm text-[#0D9488] hover:text-[#0D9488]/90 font-semibold transition">Agendemos un café estratégico →</a>
    </div>
  </nav>

  <!-- HERO -->
  <header class="py-16 px-4 bg-[#F8FAFC] border-b border-[#64748B]/20">
    <div class="container mx-auto max-w-3xl text-center">
      <span class="inline-block bg-[#64748B]/10 text-[#64748B] text-xs px-3 py-1 rounded-md mb-4 font-medium">Recursos Gratuitos</span>
      <h1 class="text-[32px] md:text-[48px] font-bold text-[#0F172A] leading-[1.1] mb-4">
        Elige tu perfil, recibe tu guía
      </h1>
      <p class="text-base text-[#64748B] max-w-2xl mx-auto leading-[1.6]">
        Contenido práctico diseñado para tu contexto real. Sin teoría. Sin relleno.
      </p>
    </div>
  </header>

  <!-- GRID DE GUÍAS -->
  <main class="py-24 px-4 bg-white">
    <div class="container mx-auto max-w-5xl">
      
      <div class="grid md:grid-cols-2 gap-6">
        
        <!-- ✅ PROFESIONALES (ACTIVA - CON FORMULARIO) -->
        <div class="bg-white border-2 border-[#0D9488] rounded-[12px] p-6 shadow-sm">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-[#0D9488]/10 rounded-[8px] flex items-center justify-center text-2xl flex-shrink-0">👤</div>
            <div class="flex-grow">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block bg-[#0D9488]/10 text-[#0D9488] text-[10px] font-semibold px-2 py-0.5 rounded">Disponible</span>
              </div>
              <h3 class="font-semibold text-[#0F172A] mb-1 text-base">Profesionales</h3>
              <p class="text-sm text-[#64748B] mb-3">
                Convierte notas sueltas y reportes manuales en decisiones claras con NotebookLM.
              </p>
            </div>
          </div>

          <!-- FORMULARIO DE DESCARGA -->
          <form id="leadmagnet-form-profesionales" class="space-y-3" onsubmit="handleLeadMagnetSubmit(event)">
            <input type="text" name="name" required placeholder="Nombre completo" 
                   class="w-full px-4 py-2.5 rounded-[8px] border border-[#64748B]/30 focus:ring-2 focus:ring-[#0D9488] focus:border-[#0D9488] outline-none transition bg-white text-sm" />
            
            <input type="email" name="email" required placeholder="tu@email.com" 
                   class="w-full px-4 py-2.5 rounded-[8px] border border-[#64748B]/30 focus:ring-2 focus:ring-[#0D9488] focus:border-[#0D9488] outline-none transition bg-white text-sm" />
            
            <button type="submit" id="leadmagnet-submit-btn" class="w-full bg-[#0D9488] hover:bg-[#0D9488]/90 text-white py-2.5 rounded-[8px] font-semibold text-sm flex items-center justify-center gap-2 transition">
              📥 Descargar guía gratis
            </button>
          </form>

          <div id="leadmagnet-status" class="hidden mt-3 text-center text-sm font-medium"></div>
          
          <ul class="text-xs text-[#64748B] space-y-1 mt-4">
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full"></span>
              3 prompts exactos para copiar y pegar
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full"></span>
              Plantilla de dashboard de decisión
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full"></span>
              Ejemplo con datos reales
            </li>
          </ul>

          <p class="text-[10px] text-[#64748B] mt-4 text-center">🔒 Sin spam. Solo contenido práctico.</p>
        </div>

        <!-- 🚧 EMPRESAS (PRÓXIMAMENTE) -->
        <div class="bg-[#F8FAFC] border border-[#64748B]/20 rounded-[12px] p-6 opacity-75">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#64748B]/10 rounded-[8px] flex items-center justify-center text-2xl flex-shrink-0">🏢</div>
            <div class="flex-grow">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block bg-[#64748B]/10 text-[#64748B] text-[10px] font-semibold px-2 py-0.5 rounded">Próximamente</span>
              </div>
              <h3 class="font-semibold text-[#0F172A] mb-1 text-base">Empresas</h3>
              <p class="text-sm text-[#64748B] mb-3">
                Checklist: 5 procesos operativos que puedes estandarizar con IA para reducir errores y ganar velocidad.
              </p>
              <ul class="text-xs text-[#64748B] space-y-1 mb-4">
                <li>• Mapeo de cuellos de botella</li>
                <li>• Plantilla de documentación de procesos</li>
                <li>• Casos de automatización B2B</li>
              </ul>
              <span class="text-sm text-[#64748B] cursor-not-allowed">Próximamente →</span>
            </div>
          </div>
        </div>

        <!-- 🚧 STARTUPS (PRÓXIMAMENTE) -->
        <div class="bg-[#F8FAFC] border border-[#64748B]/20 rounded-[12px] p-6 opacity-75">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#64748B]/10 rounded-[8px] flex items-center justify-center text-2xl flex-shrink-0">🚀</div>
            <div class="flex-grow">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block bg-[#64748B]/10 text-[#64748B] text-[10px] font-semibold px-2 py-0.5 rounded">Próximamente</span>
              </div>
              <h3 class="font-semibold text-[#0F172A] mb-1 text-base">Startups</h3>
              <p class="text-sm text-[#64748B] mb-3">
                Guía: Cómo integrar IA en el core de tu producto sin reescribir todo desde cero.
              </p>
              <ul class="text-xs text-[#64748B] space-y-1 mb-4">
                <li>• Framework de priorización de features con IA</li>
                <li>• Ejemplos de MVPs potenciados</li>
                <li>• Métricas de impacto temprano</li>
              </ul>
              <span class="text-sm text-[#64748B] cursor-not-allowed">Próximamente →</span>
            </div>
          </div>
        </div>

        <!-- 🚧 EDUCACIÓN (PRÓXIMAMENTE) -->
        <div class="bg-[#F8FAFC] border border-[#64748B]/20 rounded-[12px] p-6 opacity-75">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#64748B]/10 rounded-[8px] flex items-center justify-center text-2xl flex-shrink-0">🎓</div>
            <div class="flex-grow">
              <div class="flex items-center gap-2 mb-2">
                <span class="inline-block bg-[#64748B]/10 text-[#64748B] text-[10px] font-semibold px-2 py-0.5 rounded">Próximamente</span>
              </div>
              <h3 class="font-semibold text-[#0F172A] mb-1 text-base">Educación</h3>
              <p class="text-sm text-[#64748B] mb-3">
                Recursos para cerrar la brecha academia-industria con formación práctica en IA.
              </p>
              <ul class="text-xs text-[#64748B] space-y-1 mb-4">
                <li>• Syllabus de IA aplicada para estudiantes</li>
                <li>• Plantillas de proyectos reales</li>
                <li>• Guía para docentes</li>
              </ul>
              <span class="text-sm text-[#64748B] cursor-not-allowed">Próximamente →</span>
            </div>
          </div>
        </div>

      </div>

      <!-- CTA SECUNDARIO: Si ninguna guía encaja -->
      <div class="mt-16 text-center">
        <p class="text-sm text-[#64748B] mb-4">
          ¿Ninguna guía encaja con tu contexto?
        </p>
        <a 
          href="/#cta"
          class="inline-flex items-center justify-center gap-2 bg-[#0D9488] hover:bg-[#0D9488]/90 text-white px-[28px] py-[14px] rounded-[8px] text-sm font-semibold transition shadow-sm"
        >
          Agendemos un café estratégico (30 min) →
        </a>
        <p class="text-xs text-[#64748B] mt-3">
          ✨ Sin compromiso. Si en 15 min ya hay claridad, cerramos antes.
        </p>
      </div>

    </div>
  </main>

  <!-- FOOTER SIMPLE -->
  <footer class="bg-[#0F172A] border-t border-[#64748B]/20 py-10 px-4">
    <div class="container mx-auto max-w-4xl flex justify-between items-center text-xs text-[#64748B]">
      <p>© 2026 LuciRMe Ai · Recursos Gratuitos</p>
      <a href="/" class="hover:text-[#0D9488] transition">← Volver al inicio</a>
    </div>
  </footer>

  <!-- SCRIPT DEL FORMULARIO -->
  <script is:inline>
    async function handleLeadMagnetSubmit(e) {
      e.preventDefault();
      const form = e.target;
      const btn = document.getElementById('leadmagnet-submit-btn');
      const status = document.getElementById('leadmagnet-status');
      
      btn.disabled = true;
      btn.textContent = '⏳ Enviando...';
      status.classList.add('hidden');

      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('/api/leadmagnet-access', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await res.json();

        if (res.ok) {
          form.reset();
          status.textContent = '✅ ¡Listo! Revisa tu correo en minutos.';
          status.className = 'mt-3 text-center text-sm font-medium text-[#10B981]';
          status.classList.remove('hidden');
          
          setTimeout(() => {
            status.classList.add('hidden');
            btn.disabled = false;
            btn.textContent = '📥 Descargar guía gratis';
          }, 5000);
        } else {
          throw new Error(result.error || 'Error en el servidor');
        }
      } catch (err) {
        status.textContent = '⚠️ ' + err.message;
        status.className = 'mt-3 text-center text-sm font-medium text-[#EA580C]';
        status.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = '🔄 Intentar de nuevo';
      }
    }
  </script>

</Layout>