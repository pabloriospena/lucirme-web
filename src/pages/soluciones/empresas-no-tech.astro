---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Automatización IA para Equipos No-Tech | LuciRMe Ai">

  <!-- NAV SIMPLE (Brand Book) -->
  <nav class="sticky top-0 z-50 bg-[#F8FAFC]/90 backdrop-blur border-b border-[#64748B]/20 px-4 py-3">
    <div class="container mx-auto max-w-6xl flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 text-sm text-[#64748B] hover:text-[#0F172A] transition">
        ← Volver a LuciRMe Ai
      </a>
      <a href="#contacto" class="hidden md:inline-flex items-center gap-2 bg-[#0D9488] hover:bg-[#0D9488]/90 text-white px-[28px] py-[14px] rounded-[8px] text-sm font-semibold transition">
        Agendemos un café
      </a>
    </div>
  </nav>

  <!-- ============================================ -->
  <!-- HERO (Brand Book Typography & Colors)        -->
  <!-- ============================================ -->
  <section class="py-24 px-4 bg-[#F8FAFC] border-b border-[#64748B]/20">
    <div class="container mx-auto max-w-4xl text-center">
      <span class="inline-block bg-[#64748B]/10 text-[#64748B] text-xs px-3 py-1 rounded-md mb-6 font-medium">
        Para Equipos Operativos y Administrativos
      </span>
      
      <h1 class="text-[32px] md:text-[48px] font-bold text-[#0F172A] leading-[1.1] mb-6">
        Transformemos tu equipo operativo con IA.
      </h1>
      
      <p class="text-base md:text-lg text-[#64748B] mb-10 max-w-3xl mx-auto leading-[1.6]">
        Tu equipo pierde horas en tareas manuales que se pueden ahorrar hoy. 
        No se trata de comprar software costoso, sino de desbloquear el potencial que ya tienes con herramientas gratuitas de IA.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-6">
        <a href="#contacto" class="inline-flex items-center justify-center gap-2 bg-[#0D9488] hover:bg-[#0D9488]/90 text-white px-[28px] py-[14px] rounded-[8px] text-sm font-semibold transition">
          Agendemos un café estratégico →
        </a>
        <a href="#proceso" class="inline-flex items-center justify-center gap-2 bg-white border border-[#64748B]/30 hover:border-[#0D9488] text-[#0F172A] px-[28px] py-[14px] rounded-[8px] text-sm font-semibold transition">
          Ver cómo lo hacemos
        </a>
      </div>

      <p class="text-xs text-[#64748B]">
        ✨ Sin compromiso. Si en 15 min ya hay claridad, cerramos antes.
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- EL PROBLEMA / LA SOLUCIÓN                    -->
  <!-- ============================================ -->
  <section class="py-20 px-4 bg-white">
    <div class="container mx-auto max-w-3xl text-center">
      <h2 class="text-[32px] font-semibold text-[#0F172A] mb-6 leading-[1.2]">
        El problema no es la tecnología, es el proceso
      </h2>
      <p class="text-base text-[#64748B] leading-[1.6]">
        Muchas empresas creen que necesitan "digitalizarse" gastando fortunas. La realidad es que tu equipo ya tiene las herramientas. 
        Solo necesitan saber cómo conectarlas para dejar de repetir tareas manuales y empezar a escalar. 
        <strong class="text-[#0F172A]">Nosotros te enseñamos cómo, paso a paso.</strong>
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- EL PROCESO (TIMELINE - Brand Book Cards)     -->
  <!-- ============================================ -->
  <section id="proceso" class="py-24 px-4 bg-[#F8FAFC]">
    <div class="container mx-auto max-w-5xl">
      
      <div class="text-center mb-16">
        <h2 class="text-[32px] font-semibold text-[#0F172A] mb-4 leading-[1.2]">
          El Camino hacia la Autonomía
        </h2>
        <p class="text-base text-[#64748B] leading-[1.6]">
          Así es como trabajamos juntos para garantizar resultados reales.
        </p>
      </div>

      <div class="space-y-8">
        
        <!-- Paso 0: Conexión -->
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 bg-[#0D9488]/10 text-[#0D9488] rounded-[8px] flex items-center justify-center font-bold text-base">0</div>
          <div>
            <h3 class="text-base font-semibold text-[#0F172A] mb-2">Espacio de Conexión (30 min)</h3>
            <p class="text-sm text-[#64748B] leading-relaxed">
              Una llamada breve y sin compromiso. Escuchamos tu situación, identificamos tus cuellos de botella y confirmamos si hay <em>fit</em> para trabajar juntos.
            </p>
          </div>
        </div>

        <!-- Fase 1: Inmersión -->
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 bg-[#0D9488] text-white rounded-[8px] flex items-center justify-center font-bold text-base">1</div>
          <div class="flex-1 bg-white p-6 rounded-[12px] border border-[#64748B]/20">
            <h3 class="text-base font-semibold text-[#0F172A] mb-2">Fase 1: Taller de Inmersión e Identificación</h3>
            <p class="text-xs text-[#64748B] font-semibold mb-3 uppercase tracking-wide">Sesión única de 2 horas</p>
            <p class="text-sm text-[#64748B] leading-relaxed mb-4">
              El primer paso para despertar el potencial del equipo. Identificamos en tiempo real las <strong class="text-[#0F172A]">"fugas de tiempo"</strong> y construimos una solución inmediata con <strong class="text-[#0F172A]">archivos propios de la empresa</strong>.
            </p>
            <div class="bg-[#F8FAFC] p-4 rounded-[8px] border-l-[3px] border-[#0D9488] text-sm text-[#0F172A]">
              ✨ <strong class="font-semibold">Resultado:</strong> Salimos con una primera automatización funcionando el mismo día.
            </div>
          </div>
        </div>

        <!-- Fase 2: Entrenamiento PRP -->
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 bg-[#0D9488] text-white rounded-[8px] flex items-center justify-center font-bold text-base">2</div>
          <div class="flex-1 bg-white p-6 rounded-[12px] border border-[#64748B]/20">
            <h3 class="text-base font-semibold text-[#0F172A] mb-2">Fase 2: Entrenamiento de Alto Rendimiento</h3>
            <p class="text-xs text-[#64748B] font-semibold mb-3 uppercase tracking-wide">8 Semanas (2 Meses) · 4h/semana</p>
            <p class="text-sm text-[#64748B] leading-relaxed mb-6">
              Construimos el "Kit de Herramientas" propio de tu empresa bajo la metodología <strong class="text-[#0F172A]">PRP</strong>.
            </p>
            
            <!-- PRP Grid (Brand Book) -->
            <div class="grid md:grid-cols-3 gap-4 mb-6">
              <div class="bg-[#F8FAFC] p-4 rounded-[8px] border border-[#0D9488]/20 text-center">
                <span class="block text-[24px] font-bold text-[#0D9488] mb-1">P</span>
                <span class="block text-[10px] font-semibold text-[#0F172A] uppercase">Protocolos</span>
                <p class="text-[10px] text-[#64748B] mt-1">Mapeamos y ordenamos tus procesos clave.</p>
              </div>
              <div class="bg-[#F8FAFC] p-4 rounded-[8px] border border-[#0D9488]/20 text-center">
                <span class="block text-[24px] font-bold text-[#0D9488] mb-1">R</span>
                <span class="block text-[10px] font-semibold text-[#0F172A] uppercase">Refinamiento</span>
                <p class="text-[10px] text-[#64748B] mt-1">Integramos IA práctica para ejecutar sin errores.</p>
              </div>
              <div class="bg-[#F8FAFC] p-4 rounded-[8px] border border-[#0D9488]/20 text-center">
                <span class="block text-[24px] font-bold text-[#0D9488] mb-1">P</span>
                <span class="block text-[10px] font-semibold text-[#0F172A] uppercase">Potencial</span>
                <p class="text-[10px] text-[#64748B] mt-1">Entregamos autonomía: tu equipo escala sin nosotros.</p>
              </div>
            </div>

            <ul class="space-y-2 text-sm text-[#64748B]">
              <li class="flex items-start gap-2">
                <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full mt-1.5"></span>
                <span><strong class="text-[#0F172A]">Automatización Avanzada:</strong> Flujos complejos según necesidad.</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full mt-1.5"></span>
                <span><strong class="text-[#0F172A]">Seguimiento Individual:</strong> Monitoreo personalizado para nuevos hábitos.</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Fase 3: Consolidación -->
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-12 h-12 bg-[#0D9488] text-white rounded-[8px] flex items-center justify-center font-bold text-base">3</div>
          <div class="flex-1 bg-white p-6 rounded-[12px] border border-[#64748B]/20">
            <h3 class="text-base font-semibold text-[#0F172A] mb-2">Fase 3: Consolidación y Autonomía</h3>
            <p class="text-xs text-[#64748B] font-semibold mb-3 uppercase tracking-wide">8 Semanas Adicionales · 2h/semana</p>
            <p class="text-sm text-[#64748B] leading-relaxed">
              Acompañamiento para asegurar que el equipo vuele solo. Refinamos soluciones, resolvemos casos avanzados y <strong class="text-[#0F172A]">certificamos la independencia técnica</strong> del equipo.
            </p>
          </div>
        </div>

        <!-- Opcional: Check-ins -->
        <div class="flex gap-6 items-start pl-6 opacity-75">
          <div class="flex-shrink-0 w-12 h-12 bg-[#64748B]/10 text-[#64748B] rounded-[8px] flex items-center justify-center font-bold text-base">+</div>
          <div>
            <h3 class="text-sm font-semibold text-[#0F172A] mb-1">Opcional: Check-ins de Actualización</h3>
            <p class="text-[#64748B] text-sm leading-relaxed">
              Seguro de actualización y soporte constante. 1 sesión virtual breve cada 2 semanas para ajustar flujos y dudas puntuales.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- RESULTADOS Y GARANTÍA (Brand Book Dark)      -->
  <!-- ============================================ -->
  <section class="py-24 px-4 bg-white text-black">
    <div class="container mx-auto max-w-5xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        
        <div>
          <h2 class="text-[32px] font-semibold mb-6 leading-[1.2]">Resultados Tangibles</h2>
          <ul class="space-y-4 text-base text-[#64748B]">
            <li class="flex items-start gap-3">
              <span class="text-[#10B981] mt-1">✓</span>
              <span>Reducción mínima de <strong class="text-black">20h semanales</strong> en tareas operativas manuales.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#10B981] mt-1">✓</span>
              <span>Equipos capacitados en herramientas de tecnología para trabajos avanzados.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#10B981] mt-1">✓</span>
              <span>Sesiones personalizadas enfocadas en ver resultados desde la semana 1.</span>
            </li>
          </ul>
        </div>

        <div class="bg-[#64748B]/10 p-6 rounded-[12px] border border-[#0D9488]/30">
          <h3 class="text-base font-semibold text-[#0D9488] mb-4">Nuestra Garantía</h3>
          <p class="text-sm text-[#64748B] leading-relaxed mb-4">
            <strong class="text-black">Propiedad Intelectual Total:</strong> Tu equipo es dueño de sus propios asistentes, flujos y bibliotecas de prompts.
          </p>
          <p class="text-xs text-[#64748B]">
            No creamos dependencia. Creamos capacidad instalada en tu empresa.
          </p>
        </div>

      </div>
    </div>
  </section>

<!-- ============================================ -->
  <!-- LEAD MAGNET SECTION (Empresas)              -->
  <!-- ============================================ -->
  <section class="py-16 px-4 bg-gradient-to-br from-[#0D9488]/10 to-[#F8FAFC] border-y border-[#0D9488]/20">
    <div class="container mx-auto max-w-3xl text-center">
      <div class="mb-6">
        <span class="inline-block bg-[#0D9488]/10 text-[#0D9488] text-xs font-semibold px-3 py-1 rounded-full mb-3">📄 Propuesta Comercial</span>
        <h3 class="text-[32px] font-bold text-[#0F172A] mb-2 leading-[1.2]">Descarga la propuesta completa para tu equipo</h3>
        <p class="text-base text-[#64748B] leading-[1.6]">
          Conoce el plan detallado, inversión y casos de éxito. <br>
          <strong class="text-[#0F172A]">Sin compromiso · Early Adopters disponibles</strong>
        </p>
      </div>

      <!-- BOTÓN DEL LEAD MAGNET -->
      <button 
        onclick="openPropuestaModal()" 
        class="inline-flex items-center justify-center gap-2 bg-white hover:bg-[#0D9488]/5 text-[#0D9488] border-2 border-[#0D9488] px-[28px] py-[14px] rounded-[8px] font-semibold text-sm transition shadow-sm hover:shadow-md"
      >
        📥 Descargar propuesta + ver precios
      </button>

      <p class="text-[10px] text-[#64748B] mt-4">🔒 Sin spam · Solo recibirás la propuesta y seguimiento si lo solicitas</p>
    </div>
  </section>

  <!-- MODAL DE CAPTURA (Empresas) -->
  <div id="propuesta-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm" aria-hidden="true" role="dialog">
    <div class="relative mx-auto w-full max-w-md bg-white rounded-[12px] shadow-2xl p-8 transform transition-all">
      <button onclick="closePropuestaModal()" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-[#F8FAFC] text-[#64748B] hover:bg-[#64748B]/10 transition" aria-label="Cerrar">✕</button>
      
      <div class="text-center mb-6">
        <div class="w-12 h-12 bg-[#0D9488]/10 rounded-[8px] flex items-center justify-center text-2xl mx-auto mb-3">🏢</div>
        <h3 class="text-xl font-bold text-[#0F172A] mb-2">Propuesta para Equipos</h3>
        <p class="text-sm text-[#64748B]">Déjanos tus datos y recibe:</p>
        <ul class="text-xs text-[#64748B] mt-3 space-y-1 text-left">
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full"></span>
            PDF con metodología PRP detallada
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full"></span>
            Inversión y planes disponibles
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-[#10B981] rounded-full"></span>
            Casos de éxito y métricas reales
          </li>
        </ul>
      </div>

      <form id="propuesta-empresas-form" class="space-y-3" onsubmit="handlePropuestaSubmit(event)">
        <input type="text" name="name" required placeholder="Nombre completo" 
               class="w-full px-4 py-2.5 rounded-[8px] border border-[#64748B]/30 focus:ring-2 focus:ring-[#0D9488] focus:border-[#0D9488] outline-none transition bg-white text-sm" />
        <input type="email" name="email" required placeholder="tu@empresa.com" 
               class="w-full px-4 py-2.5 rounded-[8px] border border-[#64748B]/30 focus:ring-2 focus:ring-[#0D9488] focus:border-[#0D9488] outline-none transition bg-white text-sm" />
        <input type="text" name="company" placeholder="Nombre de la empresa (opcional)" 
               class="w-full px-4 py-2.5 rounded-[8px] border border-[#64748B]/30 focus:ring-2 focus:ring-[#0D9488] focus:border-[#0D9488] outline-none transition bg-white text-sm" />
        
        <button type="submit" id="propuesta-submit-btn" class="w-full bg-[#0D9488] hover:bg-[#0D9488]/90 text-white py-2.5 rounded-[8px] font-semibold text-sm flex items-center justify-center gap-2 transition">
          📥 Recibir propuesta ahora
        </button>
      </form>

      <div id="propuesta-status" class="hidden mt-3 text-center text-sm font-medium"></div>
      <p class="text-[10px] text-[#64748B] text-center mt-4">🔒 Sin spam. Solo contenido práctico.</p>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- CTA FINAL (Brand Book)                       -->
  <!-- ============================================ -->
  <section id="contacto" class="py-24 px-4 bg-white">
    <div class="container mx-auto max-w-2xl text-center">
      
      <h2 class="text-[32px] font-semibold text-[#0F172A] mb-4 leading-[1.2]">Agenda un Espacio para Hablar</h2>
      <p class="text-base text-[#64748B] mb-8 leading-[1.6]">
        Selecciona el horario que mejor te funcione. Confirmación inmediata en tu correo y en el mío.
      </p>

      <!-- Botón directo a Google Calendar -->
      <a 
        href="https://calendar.app.google/k4iYmA42X9NNBb5t8" 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-[#0D9488] hover:bg-[#0D9488]/90 text-white px-[28px] py-[14px] rounded-[8px] text-sm font-semibold transition shadow-sm w-full sm:w-auto mb-6"
      >
        Agendemos un café estratégico (30 min) →
      </a>

      <p class="text-xs text-[#64748B]">
        🔒 Sin spam · 📅 Confirmación instantánea · ⏱️ Respuesta en &lt;24h
      </p>

    </div>
  </section>

    

  <script is:inline>
    function openPropuestaModal() {
      const modal = document.getElementById('propuesta-modal');
      if (modal) {
        modal.classList.remove('hidden');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        setTimeout(() => modal.querySelector('input')?.focus(), 100);
      }
    }
    function closePropuestaModal() {
      const modal = document.getElementById('propuesta-modal');
      if (modal) {
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }
    }
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePropuestaModal(); });
    
    async function handlePropuestaSubmit(e) {
      e.preventDefault();
      const form = e.target;
      const btn = document.getElementById('propuesta-submit-btn');
      const status = document.getElementById('propuesta-status');
      
      btn.disabled = true;
      btn.textContent = '⏳ Enviando...';
      status.classList.add('hidden');

      try {
        const data = Object.fromEntries(new FormData(form));
        const res = await fetch('/api/leadmagnet-access', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            ...data, 
            source: 'empresas_propuesta',
            interest: 'propuesta_comercial_empresas'
          })
        });

        const result = await res.json();

        if (res.ok) {
          form.reset();
          status.textContent = '✅ ¡Listo! Revisa tu correo. La propuesta está en camino.';
          status.className = 'mt-3 text-center text-sm font-medium text-[#10B981]';
          status.classList.remove('hidden');
          
          setTimeout(() => {
            closePropuestaModal();
            form.reset();
            status.classList.add('hidden');
            btn.disabled = false;
            btn.textContent = '📥 Recibir propuesta ahora';
          }, 3000);
        } else {
          throw new Error(result.error || 'Error en el servidor');
        }
      } catch (err) {
        status.textContent = '⚠️ ' + err.message;
        status.className = 'mt-3 text-center text-sm font-medium text-[#EA580C]';
        status.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = '🔄 Intentar de nuevo';
      }
    }
  </script>

  <!-- FOOTER (Brand Book Dark) -->
  <footer class="bg-[#0F172A] border-t border-[#64748B]/20 py-10 px-4">
    <div class="container mx-auto max-w-6xl flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col items-center md:items-start gap-2">
        <img src="/logo-lucirme.png" alt="LuciRMe Ai" class="h-5 opacity-60" />
        <p class="text-[10px] text-[#64748B]">© 2026 LuciRMe Ai · Medellín, Colombia.</p>
      </div>
      <a href="/" class="text-xs text-[#64748B] hover:text-[#0D9488] transition">← Volver al Inicio</a>
    </div>
  </footer>

</Layout>