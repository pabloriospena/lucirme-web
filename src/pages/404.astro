---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 | No encontrado">
  <div class="min-h-screen bg-slate-900 flex flex-col items-center justify-center text-center px-4">
    <h1 class="text-6xl font-bold text-cyan-400 mb-4">404</h1>
    <p class="text-xl text-slate-300 mb-8">Oops. Esta página no existe o se movió.</p>
    <a href="/" class="bg-cyan-600 hover:bg-cyan-500 text-white px-6 py-3 rounded-lg font-semibold transition">
      Volver al Inicio
    </a>
  </div>
</Layout>